# Copy to .env for local dev (never commit .env)

OPENAI_API_KEY=
# Screenshot reading (vision) and recommendations both use this key.
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_RECOMMEND_MODEL=gpt-4o-mini

# Strong random string (required on Vercel)
# FLASK_SECRET_KEY=

# Vercel / production: paste full contents of Google OAuth JSON (Web application client)
# GOOGLE_CLIENT_SECRET_JSON={"web":{"client_id":"...","client_secret":"...", ...}}

# Optional: force public URL if VERCEL_URL is wrong (custom domain)
# PUBLIC_BASE_URL=https://your-app.vercel.app
